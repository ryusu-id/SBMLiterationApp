{
	"ConnectionStrings": {
		"DefaultConnection": "Host=localhost;Database=puretcowebappdb;Username=postgres;Password=postgres;"
	},
	"MinIO": {
		"Endpoint": "localhost:9000",
		"AccessKey": "minioadmin",
		"SecretKey": "minioadmin",
		"UseSSL": false,
		"BucketName": "puretco-uploads",
		"PublicUrl": "http://localhost:9000"
	},
	"GoogleAuthCredentials": {
		"ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET",
		"ClientId": "YOUR_GOOGLE_CLIENT_ID"
	},
	"GoogleOAuth": {
		"RedirectUri": "http://localhost:3000/auth/callback"
	},
	"GoogleBooks": {
		"ApiKey": "your-google-books-api-key",
		"BaseUrl": "https://www.googleapis.com/books/v1/"
	},
	"CrossRef": {
		"BaseUrl": "https://api.crossref.org/"
	},
	"Jwt": {
		"SecretKey": "your-super-secret-jwt-key-change-this-in-production-minimum-32-characters",
		"Issuer": "PureTCOWebApp",
		"Audience": "PureTCOWebApp",
		"AccessTokenExpirationMinutes": "60",
		"RefreshTokenExpirationDays": "7"
	},
	"Email": {
		"SmtpHost": "smtp.gmail.com",
		"SmtpPort": 587,
		"SenderEmail": "your@email.com",
		"SenderName": "SBM Literation App",
		"AppPassword": "YOUR_GMAIL_APP_PASSWORD"
	},
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"Cors": {
		"AllowedOrigins": []
	},
	"Outbox": {
		"MaxResilienceCount": 5,
		"ProcessingIntervalSeconds": 60,
		"MaxConcurrentProcessing": 4
	},
	"Vapid": {
		"Subject": "mailto:your@email.com",
		"PublicKey": "YOUR_VAPID_PUBLIC_KEY",
		"PrivateKey": "YOUR_VAPID_PRIVATE_KEY"
	},
	"AllowedHosts": "*"
}
